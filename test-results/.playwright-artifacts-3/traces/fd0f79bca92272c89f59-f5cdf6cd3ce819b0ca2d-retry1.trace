e:height","content":"630"}],["META",{"property":"og:site_name","content":"I am speed."}],["META",{"name":"twitter:card","content":"summary_large_image"}],["META",{"name":"twitter:title","content":"I am speed. LLM API Benchmark"}],["META",{"name":"twitter:description","content":"A fast.com style benchmarking tool for LLM APIs. Pick a provider and model, and see live streaming output with real-time throughput metrics."}],["META",{"name":"twitter:image","content":"https://iamspeed.dev/iamspeed-og.png"}],["META",{"name":"twitter:image:alt","content":"I am speed - fast.com style but for LLMs"}],["LINK",{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["LINK",{"rel":"preconnect","href":"https://fonts.gstatic.com","crossorigin":""}],["LINK",{"href":"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500;600&display=swap","rel":"stylesheet"}],["STYLE",{},".weather-container {\n  position: fixed;\n  inset: 0;\n  z-index: -1;\n  overflow: hidden;\n  pointer-events: none;\n  width: 100%;\n  height: 100%;\n  transition: background 0.8s ease-in-out;\n}\n\n/* Day/Light Gradient Background */\n.weather-container.light {\n  background: var(--bg-gradient);\n}\n\n/* Night/Dark Gradient Background */\n.weather-container.dark {\n  background: var(--bg-gradient);\n}\n"],"\n",["STYLE",{},".llm-app {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  position: relative;\n}\n\n/* Top bar */\n.llm-topbar {\n  width: 100%;\n  max-width: var(--max-w);\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 1.25rem 0 0;\n}\n.llm-brand {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n  line-height: 1.1;\n}\n.llm-brand-logo {\n  position: relative;\n  display: inline-block;\n  cursor: pointer;\n}\n.llm-brand-logo img {\n  width: 32px;\n  height: 32px;\n  display: block;\n  transition: filter 0.3s ease;\n}\n\n/* === Thunderstorm lightning hover === */\n\n/* Theme colors */\n:root {\n  --zap-aura: rgba(250, 204, 21, 0.5);\n}\n[data-theme=\"dark\"] {\n  --zap-aura: rgba(165, 180, 252, 0.5);\n}\n\n/* The logo shakes violently and glows like it's being struck */\n.llm-brand-logo:hover img {\n  animation: zap-strike 0.65s ease-in-out;\n}\n\n/* Radial flash — the bright burst of light around the strike point */\n.llm-brand-logo::before {\n  content: \"\";\n  position: absolute;\n  inset: -14px;\n  border-radius: 50%;\n  background: radial-gradient(circle, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.3) 30%, transparent 68%);\n  opacity: 0;\n  pointer-events: none;\n  z-index: 1;\n}\n.llm-brand-logo:hover::before {\n  animation: zap-double-flash 0.65s ease-out;\n}\n\n/* Jagged lightning bolt crack overlay */\n.llm-brand-logo::after {\n  content: \"\";\n  position: absolute;\n  top: -18px;\n  bottom: -18px;\n  left: 50%;\n  transform: translateX(-50%);\n  width: 18px;\n  background: var(--zap-bolt-color, rgba(255,255,255,0.95));\n  clip-path: polygon(\n    46% 0%, 32% 30%, 50% 27%,\n    22% 60%, 48% 54%,\n    14% 100%, 58% 58%, 36% 63%, 72% 20%\n  );\n  opacity: 0;\n  pointer-events: none;\n  z-index: 2;\n}\n[data-theme=\"dark\"] .llm-brand-logo::after {\n  --zap-bolt-color: rgba(224, 231, 255, 0.97);\n}\n.llm-brand-logo:hover::after {\n  animation: zap-bolt-flash 0.65s ease-out;\n}\n\n/* Thunder-shake + pulsing electric aura */\n@keyframes zap-strike {\n  0%, 100% {\n    transform: translate(0,0) scale(1);\n    filter: drop-shadow(0 0 0 transparent);\n  }\n  8% {\n    transform: translate(-2px,-1px) scale(1.12);\n    filter:\n      drop-shadow(0 0 8px var(--zap-aura))\n      drop-shadow(0 0 18px var(--zap-aura));\n  }\n  18% {\n    transform: translate(2px,0) scale(1.12);\n    filter:\n      drop-shadow(0 0 4px var(--zap-aura))\n      drop-shadow(0 0 10px var(--zap-aura));\n  }\n  34% {\n    transform: translate(-1px,1px) scale(1.08);\n    filter:\n      drop-shadow(0 0 10px var(--zap-aura))\n      drop-shadow(0 0 22px var(--zap-aura));\n  }\n  50% {\n    transform: translate(1px,-1px) scale(1.05);\n    filter:\n      drop-shadow(0 0 3px var(--zap-aura))\n      drop-shadow(0 0 8px var(--zap-aura));\n  }\n  66% {\n    transform: translate(-1px,0) scale(1.02);\n    filter: drop-shadow(0 0 5px var(--zap-aura));\n  }\n  82% {\n    transform: translate(0,0) scale(1);\n    filter: drop-shadow(0 0 2px var(--zap-aura));\n  }\n}\n\n/* Double flash — real lightning has a bright initial stroke then a dimmer return stroke */\n@keyframes zap-double-flash {\n  0%    { opacity: 0;   transform: scale(0.2); }\n  10%   { opacity: 1;   transform: scale(1.3); }\n  24%   { opacity: 0.05; transform: scale(1.1); }\n  38%   { opacity: 0.8; transform: scale(1.25); }\n  100%  { opacity: 0;   transform: scale(1.7); }\n}\n\n/* Bolt crack: bright flash then afterglow */\n@keyframes zap-bolt-flash {\n  0%   { opacity: 0; }\n  8%   { opacity: 1; }\n  26%  { opacity: 0; }\n  36%  { opacity: 0.65; }\n  60%  { opacity: 0; }\n  100% { opacity: 0; }\n}\n.llm-brand-text {\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n}\n.llm-brand-name {\n  font-family: var(--body);\n  font-size: 1.5rem;\n  font-weight: 300;\n  letter-spacing: -0.03em;\n  color: var(--text);\n}\n.llm-brand-tagline {\n  font-family: var(--mono);\n  font-size: 0.6875rem;\n  font-weight: 400;\n  letter-spacing: 0.02em;\n  color: var(--text-muted);\n  margin-top: 2px;\n}\n.llm-topbar-actions {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n.llm-theme-toggle, .llm-history-btn, .llm-gear {\n  width: 40px;\n  height: 40px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  color: var(--text-muted);\n  border: none;\n  background: none;\n  padding: 0;\n  border-radius: 6px;\n  transition: color 0.3s ease-in-out, background-color 0.2s ease-in-out, transform 0.2s;\n}\n.llm-theme-toggle:hover, .llm-history-btn:hover, .llm-gear:hover {\n  color: var(--text);\n  background-color: var(--border-light);\n}\n.llm-theme-toggle:active, .llm-history-btn:active, .llm-gear:active {\n  transform: scale(0.92);\n}\n.llm-theme-toggle svg, .llm-history-btn svg, .llm-gear svg {\n  width: 20px;\n  height: 20px;\n  display: block;\n}\n\n/* Theme Morphing Icon Animations */\n.theme-toggle-icon {\n  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);\n}\n[data-theme=\"dark\"] .theme-toggle-icon {\n  transform: rotate(40deg);\n}\n\n.sun-icon {\n  opacity: 1;\n  transform: scale(1);\n  transform-origin: center;\n  transition: opacity 0.3s ease, transform 0.3s ease;\n}\n.moon-icon {\n  opacity: 0;\n  transform: scale(0.5) rotate(-45deg);\n  transform-origin: center;\n  transition: opacity 0.3s ease, transform 0.3s ease;\n}\n[data-theme=\"dark\"] .sun-icon {\n  opacity: 0;\n  transform: scale(0.5) rotate(45deg);\n}\n[data-theme=\"dark\"] .moon-icon {\n  opacity: 1;\n  transform: scale(1) rotate(0deg);\n}\n\n/* Hero area */\n.llm-hero {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  padding: 2rem 0;\n  width: 100%;\n  max-width: var(--max-w);\n}\n\n.llm-hero-result {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n.llm-hero-label {\n  font-size: 0.8125rem;\n  color: var(--text-muted);\n  margin-bottom: 0.5rem;\n  letter-spacing: 0.02em;\n}\n\n.llm-hero-number {\n  font-family: var(--mono);\n  font-size: 7rem;\n  font-weight: 300;\n  line-height: 1;\n  letter-spacing: -0.04em;\n  color: var(--text);\n  transition: color 0.2s;\n}\n.llm-hero-number.active {\n  color: var(--accent);\n}\n@media (max-width: 500px) {\n  .llm-hero-number { font-size: 4.5rem; }\n}\n\n.llm-hero-unit {\n  font-family: var(--mono);\n  font-size: 0.875rem;\n  color: var(--text-muted);\n  margin-top: 0.75rem;\n  letter-spacing: 0.05em;\n}\n\n/* TTFT callout */\n.llm-ttft {\n  margin-top: 1.5rem;\n  text-align: center;\n}\n.llm-ttft-value {\n  font-family: var(--mono);\n  font-size: 1.5rem;\n  font-weight: 600;\n  color: var(--accent);\n}\n.llm-ttft-label {\n  font-size: 0.6875rem;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin-top: 0.125rem;\n}\n\n/* Secondary metrics row */\n/* (secondary metrics styles moved to SecondaryMetrics component) */\n\n/* (action button styles moved to RunControls component) */\n\n/* (show more styles moved to ShowMoreToggle component) */\n\n/* (model context styles consolidated into CurrentSelection) */\n\n/* (styles moved into CurrentSelection component for modularity) */\n\n/* Stream section */\n.llm-stream-section {\n  width: 100%;\n  max-width: var(--max-w);\n  padding: 0 0 2rem;\n}\n\n/* (sparkline wrapper moved to HeroSparkline) */\n\n/* Error */\n.llm-error {\n  color: #cf222e;\n  font-size: 0.8125rem;\n  margin-top: 1rem;\n  text-align: center;\n  max-width: var(--max-w);\n}\n\n/* (hint styles moved to BenchmarkHint component) */\n\n/* Footer */\n.llm-footer {\n  width: 100%;\n  max-width: var(--max-w);\n  padding: 2rem 0 1.5rem;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-wrap: wrap;\n  gap: 0.5rem 0.625rem;\n  font-family: var(--mono);\n  font-size: 0.6875rem;\n  color: var(--text-muted);\n}\n.llm-footer a {\n  color: var(--text-muted);\n  text-decoration: none;\n  letter-spacing: 0.01em;\n  transition: color 0.2s ease-in-out;\n}\n.llm-footer a:hover {\n  color: var(--accent);\n}\n.llm-footer-dot {\n  color: var(--border);\n  user-select: none;\n}\n\n/* Share bar */\n.llm-share-bar {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 0.375rem;\n  margin-top: 1.5rem;\n}\n.llm-share-btn {\n  width: 40px;\n  height: 40px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  color: var(--text-muted);\n  border: none;\n  background: none;\n  padding: 0;\n  border-radius: 6px;\n  transition: color 0.3s ease-in-out, background-color 0.2s ease-in-out, transform 0.2s;\n}\n.llm-share-btn:hover {\n  color: var(--text);\n  background-color: var(--border-light);\n}\n.llm-share-btn:active {\n  transform: scale(0.92);\n}\n.llm-share-btn svg {\n  width: 20px;\n  height: 20px;\n  display: block;\n}\n.llm-share-btn.copied {\n  color: var(--accent);\n}\n\n/* Smooth color transitions for weather background switches */\n.llm-brand-name, .llm-brand-tagline, .llm-hero-number, .llm-hero-label, .llm-hero-unit,\n.llm-ttft-value, .llm-ttft-label, .llm-sec-value, .llm-sec-label, .llm-model-context,\n.llm-hint, .llm-error, .llm-share-bar {\n  transition: color 0.3s ease-in-out;\n}\n"],"\n",["STYLE",{},":root {\n  /* Default light theme (warm soft sky theme, not typical white) */\n  --bg-gradient: linear-gradient(180deg, #dbeffe 0%, #eff6ff 40%, #f8fafc 100%);\n  --bg: #f1f5f9;\n  --text: #0f172a;\n  --text-muted: #475569;\n  --accent: #2563eb;\n  --accent-hover: #1d4ed8;\n  --border: rgba(15, 23, 42, 0.12);\n  --border-light: rgba(15, 23, 42, 0.06);\n  --surface: rgba(255, 255, 255, 0.65);\n  --mono: \"Berkeley Mono\", \"JetBrains Mono\", ui-monospace, monospace;\n  --body: \"Inter\", system-ui, sans-serif;\n  --max-w: 720px;\n  --rhythm: 1.5rem;\n\n  /* Syntax Highlighting Light */\n  --json-key: #881391;\n  --json-string: #1a7f37;\n  --json-number: #0550ae;\n  --json-bool: #cf222e;\n  --json-null: #6e7781;\n}\n\n[data-theme=\"dark\"] {\n  /* Dark theme (midnight storm theme) */\n  --bg-gradient: linear-gradient(180deg, #090d16 0%, #0f172a 50%, #1e1b4b 100%);\n  --bg: #090d16;\n  --text: #f8fafc;\n  --text-muted: #94a3b8;\n  --accent: #818cf8; /* indigo-400 */\n  --accent-hover: #6366f1; /* indigo-500 */\n  --border: rgba(255, 255, 255, 0.12);\n  --border-light: rgba(255, 255, 255, 0.06);\n  --surface: rgba(15, 23, 42, 0.65);\n\n  /* Syntax Highlighting Dark */\n  --json-key: #c084fc;\n  --json-string: #4ade80;\n  --json-number: #60a5fa;\n  --json-bool: #f87171;\n  --json-null: #94a3b8;\n}\n\n*, *::before, *::after {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n