# ---- Local development (DynamoDB Local) ----
# Set these in your local .env for development.
# The DB client auto-detects local mode when DYNAMODB_ENDPOINT is set.

DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_PREFIX=iamspeed-dev
AWS_REGION=us-east-1

# ---- Production (real AWS DynamoDB) ----
# Set these in Vercel project env vars for production.
# Leave DYNAMODB_ENDPOINT unset — the client uses real AWS credentials.
#
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# DYNAMODB_TABLE_PREFIX=iamspeed-prod

# ---- Leaderboard signing secret ----
# Used to sign/verify submission tokens (HMAC).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LEADERBOARD_SECRET=dev-secret-change-in-production
