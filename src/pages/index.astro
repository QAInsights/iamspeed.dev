---
import { BenchmarkPanel } from "../components/BenchmarkPanel";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('iamspeed_theme');
        const theme = stored || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <!-- Content Security Policy -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; connect-src 'self' https://api.openai.com https://api.anthropic.com https://api.groq.com https://openrouter.ai https://generativelanguage.googleapis.com https://models.dev https://www.google-analytics.com https://analytics.google.com http://localhost:* http://127.0.0.1:* http://[::1]:* https://*.ngrok-free.app https://*.ngrok.io https://*.trycloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.google-analytics.com https://analytics.google.com; frame-src 'none'; object-src 'none';" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GV6SZ030N3" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-GV6SZ030N3');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>I am speed. A fast.com-style benchmarking tool for LLM APIs.</title>
    <meta name="description" content="A fast.com style benchmarking tool for LLM APIs. Pick a provider and model, and see live streaming output with real-time throughput metrics. Race Mode lets you run multiple providers in parallel and watch them race side-by-side." />
    
    <!-- Browsers & SEO -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0046cc" />
    <link rel="canonical" href="https://iamspeed.dev/" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    
    <!-- Apple Mobile Web App -->
    <link rel="apple-touch-icon" href="/logo.svg" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="I am speed." />
    
    <!-- Open Graph -->
    <meta property="og:title" content="I am speed. LLM API Benchmark" />
    <meta property="og:description" content="A fast.com style benchmarking tool for LLM APIs. Pick a provider and model, and see live streaming output with real-time throughput metrics. Race Mode lets you run multiple providers in parallel and watch them race side-by-side." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://iamspeed.dev/" />
    <meta property="og:image" content="https://iamspeed.dev/iamspeed-og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="I am speed." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="I am speed. LLM API Benchmark" />
    <meta name="twitter:description" content="A fast.com style benchmarking tool for LLM APIs. Pick a provider and model, and see live streaming output with real-time throughput metrics. Race Mode lets you run multiple providers in parallel and watch them race side-by-side." />
    <meta name="twitter:image" content="https://iamspeed.dev/iamspeed-og.png" />
    <meta name="twitter:image:alt" content="I am speed - fast.com style but for LLMs" />

    <!-- Schema.org JSON-LD Structured Data for AEO -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "I am speed. A fast.com-style benchmarking tool for LLM APIs",
        "url": "https://iamspeed.dev/",
        "description": "A fast.com style benchmarking tool for LLM APIs. Pick a provider and model, and see live streaming output with real-time throughput metrics. Race Mode lets you run multiple providers in parallel and watch them race side-by-side.",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "All",
        "browserRequirements": "Requires JavaScript. Requires HTML5.",
        "softwareVersion": "0.1.0",
        "offers": {
          "@type": "Offer",
          "price": "0.00",
          "priceCurrency": "USD"
        }
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <BenchmarkPanel client:load />
  </body>
</html>
