---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Content Security Policy -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; connect-src 'self' https://api.openai.com https://api.anthropic.com https://api.groq.com https://api.cerebras.ai https://api.fireworks.ai https://api.mistral.ai https://openrouter.ai https://generativelanguage.googleapis.com https://models.dev https://www.google-analytics.com https://analytics.google.com http://localhost:* http://127.0.0.1:* http://[::1]:* https://*.ngrok-free.app https://*.ngrok.io https://*.trycloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.google-analytics.com https://analytics.google.com; frame-src 'none'; object-src 'none';" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404: Outrun the Speed — I am speed.</title>
    <meta name="description" content="You went too fast and hit a dead end. Let's get you back to benchmarking." />
    
    <!-- Icons -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0046cc" />
    <meta name="robots" content="noindex, follow" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="error-container">
      <div class="speedometer">
        <span class="speed-number">404</span>
        <span class="speed-unit">ERR / SEC</span>
      </div>
      <div class="message-group">
        <h1 class="title">You went too fast.</h1>
        <p class="description">You outran the route registry and landed out of bounds.</p>
      </div>
      <a href="/" class="btn-home">Return to Speed Test</a>
    </main>
  </body>
</html>

<style>
  .error-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--rhythm);
    text-align: center;
  }

  .speedometer {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }

  .speed-number {
    font-family: var(--mono);
    font-size: 8rem;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--accent);
    animation: jitter 0.15s infinite alternate;
  }

  .speed-unit {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-top: 0.5rem;
  }

  .message-group {
    margin-bottom: 2.5rem;
    max-width: 400px;
  }

  .title {
    font-family: var(--body);
    font-size: 1.75rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .description {
    font-size: 0.9375rem;
    color: var(--text-muted);
  }

  .btn-home {
    padding: 0.625rem 2rem;
    background: var(--text);
    color: var(--surface);
    font-weight: 600;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    border: none;
    transition: background 0.2s, transform 0.1s;
  }

  .btn-home:hover {
    background: var(--accent);
    transform: translateY(-1px);
  }

  .btn-home:active {
    transform: translateY(0);
  }

  @keyframes jitter {
    0% {
      transform: translate(0, 0);
    }
    100% {
      transform: translate(1px, -1px);
    }
  }

  @media (max-width: 500px) {
    .speed-number {
      font-size: 5rem;
    }
  }
</style>
